Theorem: AlphaTheorem
About: First theorem referencing account.deposit
Actions:
  account.deposit:
    params:
      amount: u64
    returns: crate::account::Account
  account.validate:
    params:
      account: crate::account::Account
Let:
  result:
    call:
      action: account.deposit
      args:
        amount: 100
Do:
  - must:
      action: account.validate
      args:
        account: { ref: result }
Prove:
  - assert: "true"
    because: trivial
Evidence:
  kani:
    unwind: 1
    expect: SUCCESS
Witness:
  - cover: "true"
    because: reachable
---
Theorem: BetaTheorem
About: Second theorem also referencing account.deposit
Actions:
  account.deposit:
    params:
      amount: u64
    returns: crate::account::Account
Let:
  result:
    call:
      action: account.deposit
      args:
        amount: 200
Prove:
  - assert: "true"
    because: trivial
Evidence:
  kani:
    unwind: 1
    expect: SUCCESS
Witness:
  - cover: "true"
    because: reachable
