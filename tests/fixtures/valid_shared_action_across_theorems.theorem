Let:
  result:
    call:
      action: account.deposit
      args:
        amount: 200
Prove:
  - assert: "true"
    because: trivial
Evidence:
  kani:
    unwind: 1
    expect: SUCCESS
Witness:
  - cover: "true"
    because: reachable
