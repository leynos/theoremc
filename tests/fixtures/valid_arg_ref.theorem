Theorem: ArgRef
About: Explicit ref arguments are decoded as variable references
Actions:
  graph.create:
    returns: crate::graph::Graph
  graph.attach:
    params:
      target: crate::graph::Graph
Let:
  graph:
    call:
      action: graph.create
      args: {}
  result:
    call:
      action: graph.attach
      args:
        target: { ref: graph }
Prove:
  - assert: 'true'
    because: trivially true
Evidence:
  kani:
    unwind: 1
    expect: SUCCESS
Witness:
  - cover: 'true'
    because: always reachable
