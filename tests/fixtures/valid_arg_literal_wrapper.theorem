Theorem: ArgLiteralWrapper
About: Explicit literal wrapper is decoded as a string literal
Actions:
  label.set:
    params:
      label: String
Let:
  result:
    call:
      action: label.set
      args:
        label: { literal: "graph" }
Prove:
  - assert: 'true'
    because: trivially true
Evidence:
  kani:
    unwind: 1
    expect: SUCCESS
Witness:
  - cover: 'true'
    because: always reachable
