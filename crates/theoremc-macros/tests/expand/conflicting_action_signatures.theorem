Actions:
  account.deposit:
    params:
      account: u32
    returns: bool
Witness:
  - cover: "true"
    because: reachable
Prove:
  - assert: "true"
    because: trivial
Evidence:
  kani:
    unwind: 1
    expect: SUCCESS
